# BOMY — master environment variable reference
# ─────────────────────────────────────────────────────────────────────────────
# This file documents every variable used across all apps and infra services.
# It is NOT loaded automatically by any runtime — each service has its own file.
#
# First-time setup (three files to copy and edit):
#
#   cp infra/docker/.env.example  infra/docker/.env    ← container credentials
#   cp apps/api/.env.local.example apps/api/.env.local ← API runtime config
#   cp apps/web/.env.local.example apps/web/.env.local ← web runtime config
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# INFRA — Docker Compose  (infra/docker/.env)
# ══════════════════════════════════════════════════════════════════════════════

# Postgres 16
POSTGRES_DB=bomy
POSTGRES_USER=bomy
POSTGRES_PASSWORD=changeme_local    # required; no default in compose.yml
POSTGRES_PORT=5432

# Connection URL consumed by apps/api and packages/db
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# Redis 7
REDIS_PASSWORD=changeme_local       # required; no default in compose.yml
REDIS_PORT=6379

# Connection URL consumed by apps/api
REDIS_URL=redis://:changeme_local@localhost:6379

# MinIO  (Cloudflare R2 substitute for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local  # required; min 8 chars
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Mailhog  (SMTP trap — catches all outgoing email in local dev)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025


# ══════════════════════════════════════════════════════════════════════════════
# apps/api — Fastify API server  (apps/api/.env.local)
# ══════════════════════════════════════════════════════════════════════════════

# Database — must match POSTGRES_* values in infra/docker/.env
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# Postgres TCP probe used by /ready health check
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Cache — password must match REDIS_PASSWORD in infra/docker/.env
REDIS_URL=redis://:changeme_local@localhost:6379

# Redis TCP probe used by /ready health check
REDIS_HOST=localhost
REDIS_PORT=6379

# Object storage — credentials must match MinIO vars in infra/docker/.env
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin            # = MINIO_ROOT_USER
S3_SECRET_KEY=changeme_local        # = MINIO_ROOT_PASSWORD
S3_BUCKET=bomy-local                # create this bucket in the MinIO console

# Email — Mailhog catches all mail locally; replace with real SMTP in production.
# Set EMAIL_DELIVERY_ENABLED=true in environments where you want real SMTP delivery.
# Default (false/unset) uses a no-op mailer that logs subject+to only (PII safe).
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# Auth (optional — leave both empty for local Mailhog):
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="BOMY <noreply@bomy.my>"
# MAIL_REPLY_TO=
# Comma-separated ops recipients for [BOMY Ops] alerts (seller inquiry, order_review, voucher_claim_failed):
OPS_ALERT_EMAILS=
# URLs used in email body templates (apps/api emails link to web + admin):
ADMIN_URL=http://localhost:3002

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug                     # trace | debug | info | warn | error | fatal

# OpenTelemetry — disabled locally; enable and point at a collector in staging/prod
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bomy-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# HitPay — obtain from HitPay Dashboard → Settings → API Keys
# Sandbox: https://api.sandbox.hit-pay.com
# Production: https://api.hit-pay.com
HITPAY_API_KEY=                         # from HitPay Dashboard; never commit
HITPAY_SALT=                            # separate salt key for webhook HMAC-SHA256 verification
HITPAY_API_URL=https://api.sandbox.hit-pay.com
HITPAY_WEBHOOK_URL=                     # public URL for POST /webhooks/hitpay (use ngrok locally)

# Internal service-to-service secret — shared by apps/api (verifier) and
# apps/admin (caller). Set the same value in both .env.local files.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=                    # never commit; rotate before production


# ══════════════════════════════════════════════════════════════════════════════
# apps/web — Next.js frontend  (apps/web/.env.local)
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Auth — wired in Stage 4; generate secret with: openssl rand -base64 32
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_META_ID=
# AUTH_META_SECRET=

# App URL (Stage 4 required) — base URL for HitPay post-payment redirect callbacks.
# Required: joinMembership throws if neither NEXTAUTH_URL nor APP_URL is set.
APP_URL=http://localhost:3000

# Email / notifications (Stage 5 PR #35) — apps/web sends seller-inquiry emails
# directly through @bomy/mailer; misconfig is logged and degraded to a no-op
# mailer so server actions never 500 on bad SMTP env.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="BOMY <noreply@bomy.my>"
# MAIL_REPLY_TO=
# Comma-separated ops recipients for the [BOMY Ops] seller-inquiry alert:
OPS_ALERT_EMAILS=
ADMIN_URL=http://localhost:3002

# HitPay (Stage 4) — web also calls HitPay directly for recurring billing.
# Same key/URL as apps/api; both services share the same HitPay account.
HITPAY_API_KEY=                         # from HitPay Dashboard; never commit
HITPAY_API_URL=https://api.sandbox.hit-pay.com
# Optional: per-request webhook override. If unset, HitPay uses the global
# webhook configured in the dashboard (apps/api /webhooks/hitpay).
# HITPAY_WEBHOOK_URL=

# Object storage (Stage 5 — product images). Same bucket as apps/api.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_local
S3_BUCKET=bomy-local
S3_PUBLIC_URL=http://localhost:9000/bomy-local


# ══════════════════════════════════════════════════════════════════════════════
# apps/admin — Internal ops console  (apps/admin/.env.local)
# ══════════════════════════════════════════════════════════════════════════════

# Same DATABASE_URL as apps/api
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# Internal API secret — must match apps/api INTERNAL_API_SECRET
INTERNAL_API_SECRET=

# Email / notifications (Stage 5 PR #35) — apps/admin sends payout-pending
# emails to sellers via @bomy/mailer. Same mail transport pattern as apps/web;
# admin code does not read OPS_ALERT_EMAILS or ADMIN_URL (only APP_URL).
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="BOMY <noreply@bomy.my>"
# MAIL_REPLY_TO=
# Buyer storefront base URL (used in seller-payout link to the order detail page):
APP_URL=http://localhost:3000


# ══════════════════════════════════════════════════════════════════════════════
# packages/db — Drizzle ORM + RLS  (loaded by makeDb() and drizzle-kit)
# ══════════════════════════════════════════════════════════════════════════════

# Same value as DATABASE_URL in apps/api
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# Set to "1" to enable RLS integration tests — requires live DB + migrations applied
# BOMY_RLS_READY=1
