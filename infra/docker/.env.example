# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_DB=bomy
POSTGRES_USER=bomy
# REQUIRED — set a strong password locally; never commit a real value
POSTGRES_PASSWORD=changeme_local
POSTGRES_PORT=5432

# Connection URL consumed by apps/api and packages/db
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# ── Redis ────────────────────────────────────────────────────────────────────
# REQUIRED — set a strong password locally; never commit a real value
REDIS_PASSWORD=changeme_local
REDIS_PORT=6379

# Connection URL consumed by apps/api (BullMQ, session cache)
REDIS_URL=redis://:changeme_local@localhost:6379

# ── MinIO (S3-compatible local storage) ──────────────────────────────────────
# REQUIRED — min 8 chars for ROOT_PASSWORD
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Mailhog (local SMTP trap) ─────────────────────────────────────────────────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
