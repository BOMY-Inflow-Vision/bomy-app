# Copy this file to .env.local and fill in the values.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# URL of the running apps/api service
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── i18n ─────────────────────────────────────────────────────────────────────
# Locale used when none is specified; must have a matching messages/{locale}.json
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── Auth (NextAuth.js — wired in Phase 4) ────────────────────────────────────
# AUTH_SECRET=                  # generate: openssl rand -base64 32
# AUTH_GOOGLE_ID=               # Google OAuth client ID
# AUTH_GOOGLE_SECRET=           # Google OAuth client secret
# AUTH_META_ID=                 # Meta/Facebook OAuth client ID
# AUTH_META_SECRET=             # Meta/Facebook OAuth client secret
