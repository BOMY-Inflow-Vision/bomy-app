# Copy this file to .env.local and fill in the values.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# URL of the running apps/api service
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── i18n ─────────────────────────────────────────────────────────────────────
# Locale used when none is specified; must have a matching messages/{locale}.json
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── Database ──────────────────────────────────────────────────────────────────
# Required: used by makeAuthDb() for NextAuth session storage.
DATABASE_URL=postgresql://bomy:bomy@localhost:5432/bomy

# ── Auth (NextAuth.js) ────────────────────────────────────────────────────────
AUTH_SECRET=                    # generate: openssl rand -base64 32
AUTH_GOOGLE_ID=                 # Google OAuth client ID
AUTH_GOOGLE_SECRET=             # Google OAuth client secret
# NextAuth uses FACEBOOK_ prefix for Meta OAuth:
AUTH_FACEBOOK_ID=               # Meta/Facebook OAuth app ID
AUTH_FACEBOOK_SECRET=           # Meta/Facebook OAuth app secret

# ── App URL (Stage 4 required) ────────────────────────────────────────────────
# Base URL used for HitPay post-payment redirect callbacks.
# NextAuth may set NEXTAUTH_URL automatically; APP_URL is the explicit override.
# Required — joinMembership throws if neither NEXTAUTH_URL nor APP_URL is set.
APP_URL=http://localhost:3000

# ── HitPay (Stage 4: platform membership & brand subscriptions) ───────────────
# API key from HitPay Dashboard → Settings → API Keys
HITPAY_API_KEY=
# Sandbox: https://api.sandbox.hit-pay.com  |  Prod: https://api.hit-pay.com
HITPAY_API_URL=https://api.sandbox.hit-pay.com
# Optional: per-request webhook URL override for recurring billing events.
# If unset, HitPay uses the global webhook configured in the dashboard
# (set that to the apps/api /webhooks/hitpay endpoint in production).
HITPAY_WEBHOOK_URL=

# ── Object storage (Stage 5: product image upload) ───────────────────────────
# Same MinIO/R2 bucket as apps/api. Both services share credentials.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_local
S3_BUCKET=bomy-local
# Public CDN base URL for reading stored images.
# MinIO local: http://localhost:9000/bomy-local
# R2 production: https://pub-<token>.r2.dev  (or custom domain)
S3_PUBLIC_URL=http://localhost:9000/bomy-local
