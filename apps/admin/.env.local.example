AUTH_SECRET=<run: openssl rand -base64 32>
AUTH_GOOGLE_ID=<from Google Cloud Console — same OAuth app as apps/web>
AUTH_GOOGLE_SECRET=<from Google Cloud Console>
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy

# ── HitPay (required for admin membership cancellation) ─────────────────────
HITPAY_API_KEY=<from HitPay Dashboard → Settings → API Keys>
HITPAY_API_URL=https://api.sandbox.hit-pay.com

# ── Internal job triggers ─────────────────────────────────────────────────────
# URL of apps/api — used by "Issue Now" voucher trigger server action
NEXT_PUBLIC_API_URL=http://localhost:3001
# Shared secret with apps/api — generate: openssl rand -hex 32
INTERNAL_API_SECRET=<never commit; must match INTERNAL_API_SECRET in apps/api>

# ── Email / notifications (Stage 5 PR #35) ───────────────────────────────────
# apps/admin sends payout-pending emails to sellers via @bomy/mailer. On
# misconfig the lazy singleton logs mailer_config_invalid and falls back to a
# disabled no-op so server actions never 500.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="BOMY <noreply@bomy.my>"
# MAIL_REPLY_TO=
# Buyer storefront base URL — appears in the seller-payout link to the order detail page:
APP_URL=http://localhost:3000
