# ── Required ──────────────────────────────────────────────────────────────────

# Neon prod connection string (bomy_app role — same as apps/web DATABASE_URL in Vercel)
DATABASE_URL=

# NextAuth v5 signing secret — must match apps/web AUTH_SECRET exactly
AUTH_SECRET=

# Canonical public URL of THIS admin service (Railway public URL or custom domain)
AUTH_URL=https://<admin-service>.railway.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Public URL of the buyer storefront (used in any cross-app links)
# APP_URL=https://brandsofmalaysia.com

# Secret for triggering background jobs (INTERNAL_API_SECRET on apps/api must match)
# INTERNAL_API_SECRET=

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
