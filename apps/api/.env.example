# ── Required ──────────────────────────────────────────────────────────────────

# Neon prod connection string (bomy_app role — same value as apps/web DATABASE_URL)
DATABASE_URL=

# NextAuth v5 signing secret — must match apps/web AUTH_SECRET exactly
AUTH_SECRET=

# HitPay webhook HMAC salt — must match apps/web HITPAY_SALT exactly
HITPAY_SALT=

# Redis URL — Railway adds this automatically via the Redis add-on
REDIS_URL=redis://...

# Secret for POST /internal/jobs/* routes (used by apps/admin "Issue Now")
INTERNAL_API_SECRET=

# Canonical public URL of the buyer storefront (used in email links)
APP_URL=https://brandsofmalaysia.com

# ── Optional ──────────────────────────────────────────────────────────────────

# URL of the admin app (used in ops email links — set after admin is deployed)
# ADMIN_URL=

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Server port and host (Railway overrides PORT automatically)
# PORT=3001
# HOST=0.0.0.0

# ── Email delivery (deferred — set when SMTP is ready) ────────────────────────
# EMAIL_DELIVERY_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=BOMY <contact@brandsofmalaysia.com>
# MAIL_REPLY_TO=
# OPS_ALERT_EMAILS=ops@example.com,another@example.com

# ── OpenTelemetry (disabled by default) ──────────────────────────────────────
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
