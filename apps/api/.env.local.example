# Copy this file to .env.local and fill in the values.
# Credentials must match what you set in infra/docker/.env

# ── Database (Postgres via Docker) ──────────────────────────────────────────
DATABASE_URL=postgresql://bomy:changeme_local@localhost:5432/bomy
# TCP probe vars used by /ready health check — must match Docker port mapping
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Cache (Redis via Docker) ─────────────────────────────────────────────────
REDIS_URL=redis://:changeme_local@localhost:6379
# TCP probe vars used by /ready health check — must match Docker port mapping
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Object Storage (MinIO via Docker — local substitute for Cloudflare R2) ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_local
S3_BUCKET=bomy-local
# After starting Docker, create the "bomy-local" bucket at http://localhost:9001
# Login: MINIO_ROOT_USER / MINIO_ROOT_PASSWORD from infra/docker/.env

# ── Email (Mailhog via Docker — catches all outgoing email) ─────────────────
# EMAIL_DELIVERY_ENABLED=true turns on real SMTP delivery. Default (unset/false)
# returns a no-op mailer that logs subject+to only.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="BOMY <noreply@brandsofmalaysia.com>"
# MAIL_REPLY_TO=
# Comma-separated ops recipients for [BOMY Ops] alerts:
OPS_ALERT_EMAILS=
# URLs used in email body templates (apps/api sends emails for orders/vouchers):
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
# View caught emails at http://localhost:8025

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ── OpenTelemetry (optional in local dev) ────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bomy-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Internal service-to-service ──────────────────────────────────────────────
# Shared with apps/admin — must match the value set there.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=<never commit; rotate before production>
