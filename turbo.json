{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".turbo/**"],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "DATABASE_APP_URL",
        "BOMY_RLS_READY",
        "AUTH_SECRET",
        "NEXTAUTH_URL",
        "APP_URL",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "AUTH_FACEBOOK_ID",
        "AUTH_FACEBOOK_SECRET",
        "NEXT_PUBLIC_TURNSTILE_SITEKEY",
        "TURNSTILE_SECRET_KEY",
        "BOMY_OPS_DIAGNOSTIC_TOKEN",
        "NEXT_PUBLIC_DEFAULT_LOCALE",
        "NEXT_PUBLIC_API_URL",
        "HITPAY_API_KEY",
        "HITPAY_API_URL",
        "HITPAY_SALT",
        "HITPAY_WEBHOOK_URL"
      ],
      "passThroughEnv": [
        "EMAIL_DELIVERY_ENABLED",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_SECURE",
        "SMTP_USER",
        "SMTP_PASS",
        "MAIL_FROM",
        "MAIL_REPLY_TO",
        "OPS_ALERT_EMAILS",
        "ADMIN_URL",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "S3_BUCKET",
        "S3_PUBLIC_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL", "DATABASE_APP_URL", "BOMY_RLS_READY"]
    }
  }
}
